# evermemos-rs justfile
# Usage: just <recipe>    (run `just --list` to see all)

# Default: show available recipes
default:
    @just --list

# ── Build ─────────────────────────────────────────────────────────────────────

# Compile (debug)
build:
    cargo build --bin evermemos

# Compile MCP server (debug)
build-mcp:
    cargo build --bin evermemos-mcp

# Compile MCP server (release)
build-mcp-release:
    cargo build --release --bin evermemos-mcp

# Compile (release, optimised)
build-release:
    cargo build --release --bin evermemos

# Fast type-check without producing a binary
check:
    cargo check

# Format source code
fmt:
    cargo fmt

# Run clippy linter
lint:
    cargo clippy -- -D warnings

# Install server + MCP binaries to Cargo bin directory (~/.cargo/bin by default)
install:
    cargo install --path . --bin evermemos --bin evermemos-mcp --force

# Install server + MCP binaries with BehaviorHistory feature enabled
install-behavior-history:
    cargo install --path . --features behavior-history --bin evermemos --bin evermemos-mcp --force

# Remove installed server + MCP binaries
uninstall:
    cargo uninstall evermemos-rs || true

# ── Server ────────────────────────────────────────────────────────────────────

LOG := "/tmp/evermemos.log"
PID_FILE := "/tmp/evermemos.pid"

# Build (debug) then start the server in the foreground
serve:
    cargo run --bin evermemos

# Start server in the background (health-check is handled by server_utils.py in test scripts)
start:
    #!/usr/bin/env bash
    echo "Starting evermemos-rs → log: {{LOG}}"
    cargo run --bin evermemos > {{LOG}} 2>&1 &
    echo $! > {{PID_FILE}}
    echo "PID: $!"

# Kill any running evermemos server
stop:
    #!/usr/bin/env bash
    if [ -f {{PID_FILE}} ]; then
        PID=$(cat {{PID_FILE}})
        if kill "$PID" 2>/dev/null; then
            echo "stopped (PID $PID)"
        else
            echo "not running"
        fi
        rm -f {{PID_FILE}}
    else
        pkill -x evermemos 2>/dev/null && echo "stopped" || echo "not running"
    fi

# Restart server (stop → start)
restart: stop start

# Tail server logs
logs:
    tail -f {{LOG}}

# Watch for source changes and auto-rebuild (cargo-watch)
watch:
    cargo watch -x "build --bin evermemos"

# Watch and auto-restart server on changes
watch-serve:
    cargo watch -x "run --bin evermemos"

# ── Tests ─────────────────────────────────────────────────────────────────────

DEMO := "demo"

# Run the feature-completeness test suite
test-completeness:
    python {{DEMO}}/test_completeness.py

# Run the Python↔Rust parity test suite
test-parity:
    python {{DEMO}}/parity_test.py

# Run all demo tests
test: test-completeness test-parity

# Run cargo unit tests
unit-test:
    cargo test

# ── Cassette (record / replay) ──────────────────────────────────────────────────

CASSETTE_FILE := "cassette/llm_cassette.json"

# Record all LLM / embed / rerank calls into the cassette file (uses real API tokens)
record: stop start
    @echo "⏺ Recording LLM cassette → {{CASSETTE_FILE}}"
    LLM_CASSETTE_MODE=record LLM_CASSETTE_FILE={{CASSETTE_FILE}} python {{DEMO}}/parity_test.py
    @echo "✓ Cassette written."

# Run parity tests replaying from cassette — no API calls, no tokens consumed
replay: stop start
    @echo "▶️  Replaying from cassette → {{CASSETTE_FILE}}"
    LLM_CASSETTE_MODE=replay LLM_CASSETTE_FILE={{CASSETTE_FILE}} python {{DEMO}}/parity_test.py

# Auto mode: use cassette when available, fall through to real API for new prompts
auto-test: stop start
    LLM_CASSETTE_MODE=auto LLM_CASSETTE_FILE={{CASSETTE_FILE}} python {{DEMO}}/parity_test.py

# Delete the cassette file (forces a fresh recording on next `just record`)
clean-cassette:
    rm -f {{CASSETTE_FILE}}

# ── Maintenance ───────────────────────────────────────────────────────────────

# Remove build artefacts
clean:
    cargo clean

# Delete server logfile and PID file
clean-log:
    rm -f {{LOG}} {{PID_FILE}}

# Delete the SurrealDB data directory (wipes all stored memories)
clean-data:
    rm -rf data/surreal

# Full clean: build + data + log
clean-all: clean clean-data clean-log
