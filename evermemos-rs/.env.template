# EverMemOS Rust Environment Configuration
# Copy to .env and fill in your values

# ── LLM (at least one endpoint required) ─────────────────────────────────────
# Use __ (double underscore) as separator for nested config keys
LLM__BASE_URL=http://127.0.0.1:4000
LLM__API_KEY=your-api-key-here
LLM__MODEL=gpt-4o-mini
LLM__TEMPERATURE=0.3
LLM__MAX_TOKENS=16384

# ── Vectorisation (OpenAI-compatible embedding endpoint) ─────────────────────
VECTORIZE__BASE_URL=http://127.0.0.1:4000
VECTORIZE__API_KEY=your-api-key-here
VECTORIZE__MODEL=text-embedding-3-small
VECTORIZE__DIMENSIONS=1024
VECTORIZE__BATCH_SIZE=10

# ── Reranking (optional — enables HYBRID / AGENTIC strategies) ────────────────
# Set RERANK__ENABLED=true and provide a cross-encoder endpoint (vLLM / TEI / Jina / Cohere)
# Example model: BAAI/bge-reranker-v2-m3
RERANK__ENABLED=false
RERANK__BASE_URL=
RERANK__API_KEY=
RERANK__MODEL=

# ── SurrealDB ─────────────────────────────────────────────────────────────────
# Leave as-is for embedded (single-binary) mode.
# Change to "ws://host:8000" for remote SurrealDB server.
SURREAL__ENDPOINT=rocksdb://./data/surreal
SURREAL__NS=evermem
SURREAL__DB=main
SURREAL__USER=root
SURREAL__PASS=root

# ── NATS (optional — needed only for async message ingestion) ─────────────────
NATS__URL=nats://127.0.0.1:4222
NATS__STREAM=EVERMEM
NATS__SUBJECT_MEMORIZE=evermem.memorize

# ── Server ────────────────────────────────────────────────────────────────────
SERVER__HOST=0.0.0.0
SERVER__PORT=8080

# ── Multi-tenancy headers ─────────────────────────────────────────────────────
TENANT__ORG_HEADER=X-Organization-Id
TENANT__SPACE_HEADER=X-Space-Id

# ── API key (optional, "none" disables auth) ──────────────────────────────────
API_KEY=none

# ── Logging ───────────────────────────────────────────────────────────────────
# e.g. "evermemos=debug,tower_http=info"
RUST_LOG=evermemos=info,tower_http=warn

# ── OpenTelemetry (OTLP export) ───────────────────────────────────────────────
# Set OTEL_ENABLED=true to export traces + metrics to a collector.
# Requires a running OTLP-compatible collector (e.g. docker-compose.otel.yaml).
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=evermemos-rs
